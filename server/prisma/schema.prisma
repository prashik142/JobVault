generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  jobs      Job[]
  createdAt DateTime @default(now())
}

model Job {
  id        Int      @id @default(autoincrement())

  company   String
  title     String
  location  String
  stipend   String?
  status    String
  notes     String?
  url       String   @unique

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}